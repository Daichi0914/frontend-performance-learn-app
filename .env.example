# --- Environment ---
APP_ENV=dev
ALLOWED_ORIGIN=http://localhost:3000
GHCR_REPO=yourusername/boilerplate
CLOUDFLARE_TUNNEL_TOKEN=""
NODE_ENV=development
RESTART_POLICY=no
MYSQL_VOLUME_NAME=boilerplate_mysql_dev_data
REDIS_VOLUME_NAME=boilerplate_redis_dev_data

# --- Nginx ---
NGINX_PORT=8080

# --- Database ---
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=appdb
MYSQL_USER=app_user
MYSQL_PASSWORD=your_app_password_here
MYSQL_DSN=app_user:your_app_password_here@tcp(mysql:3306)/appdb?parseTime=true&loc=Local
MYSQL_EXPOSE=3306

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_EXPOSE=6379

# --- Frontend ---
FRONTEND_TARGET=dev
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ==============================================================================
# --- GitHub Actions / CD (Deploy) Settings ---
# ==============================================================================
# 以下の設定値は、GitHubのリポジトリ設定（Settings -> Secrets and variables -> Actions）
# の各デプロイ環境（stg / prod）ごとに設定する必要があります。
#
# 【Variables (環境変数として登録)】
# NEXT_PUBLIC_API_URL: フロントエンドビルド時に参照するバックエンドAPIへの接続URL（例: http://localhost:8080/api）
#
# 【Secrets (暗号化シークレットとして登録)】
# MYSQL_ROOT_PASSWORD: MySQLのルートパスワード
# MYSQL_DATABASE: データベース名（例: appdb）
# MYSQL_USER: 一般接続用のMySQLユーザー名
# MYSQL_PASSWORD: 一般接続用のMySQLパスワード
# MYSQL_DSN: バックエンドからMySQLへの接続DSN（例: app_user:password@tcp(mysql:3306)/appdb?parseTime=true&loc=Local）
# CLOUDFLARE_TUNNEL_TOKEN: Cloudflare Tunnelのトークン（Cloudflare連携する場合）
# BASIC_AUTH_USER: ベーシック認証用ユーザー名（ステージング環境のみ）
# BASIC_AUTH_PASS: ベーシック認証用パスワード（ステージング環境のみ）
# ==============================================================================
